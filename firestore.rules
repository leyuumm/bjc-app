rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function getUserActiveBranchId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeBranchId;
    }

    function getUserActiveStoreId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeStoreId;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'ADMIN';
    }

    function isCashier() {
      return isAuthenticated() && (getUserRole() == 'CASHIER' || getUserRole() == 'ADMIN');
    }

    function isCustomer() {
      return isAuthenticated() && getUserRole() == 'CUSTOMER';
    }

    // Prevent self-escalation: user cannot change their own role, branchId, storeId, or assignments
    function isNotSelfEscalating() {
      let currentData = resource.data;
      let newData = request.resource.data;
      return (
        !('role' in newData) || newData.role == currentData.role
      ) && (
        !('branchId' in newData) || newData.branchId == currentData.branchId
      ) && (
        !('storeId' in newData) || newData.storeId == currentData.storeId
      ) && (
        !('assignedBranches' in newData) || newData.assignedBranches == currentData.assignedBranches
      ) && (
        !('assignedStores' in newData) || newData.assignedStores == currentData.assignedStores
      );
    }

    function isValidOrderStatus(status) {
      return status in ['Pending', 'Preparing', 'In Progress', 'Ready', 'Completed', 'Cancelled'];
    }

    function isValidStoreId(storeId) {
      return storeId in ['lehmuhn', 'kohfee'];
    }

    function isPositiveNumber(value) {
      return value is number && value > 0;
    }

    function isValidProductDoc(productId) {
      let data = request.resource.data;
      let meta = data.meta;
      let priceBySizeOz = meta.priceBySizeOz;
      let normalizedCategoryId = data.categoryId.lower();
      let isKohfeeFood = data.storeId == 'kohfee' && (normalizedCategoryId == 'kf-food' || normalizedCategoryId == 'food');

      return (
        data.productId == productId &&
        ('storeId' in data) &&
        isValidStoreId(data.storeId) &&
        ('productName' in data) &&
        data.productName is string &&
        data.productName.size() >= 2 &&
        ('categoryId' in data) &&
        data.categoryId is string &&
        data.categoryId.size() > 0 &&
        ('imageUrl' in data) &&
        data.imageUrl is string &&
        data.imageUrl.size() > 0 &&
        ('price' in data) &&
        isPositiveNumber(data.price) &&
        ('isAvailable' in data) &&
        data.isAvailable is bool &&
        ('meta' in data) &&
        meta is map &&
        (
          isKohfeeFood ||
          (
            ('priceBySizeOz' in meta) &&
            priceBySizeOz is map &&
            ('16' in priceBySizeOz) &&
            isPositiveNumber(priceBySizeOz['16']) &&
            (
              !('22' in priceBySizeOz) ||
              (
                isPositiveNumber(priceBySizeOz['22']) &&
                priceBySizeOz['22'] >= priceBySizeOz['16']
              )
            )
          )
        )
      );
    }

    // ─── Users ──────────────────────────────────────────────────────
    // Users can read/write their own profile. Admins can read all.
    // Self-escalation (role/assignments) is blocked.

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if (isOwner(userId) && isNotSelfEscalating()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Stores ─────────────────────────────────────────────────────
    // Public read. Only admins can write.

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Branches ───────────────────────────────────────────────────
    // Public read. Only admins can write.

    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Product Categories ─────────────────────────────────────────
    // Public read. Only admins can write.

    match /productCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Products ───────────────────────────────────────────────────
    // Public read. Only admins can write.

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProductDoc(productId);
      allow update: if isAdmin() && isValidProductDoc(productId);
      allow delete: if isAdmin();
    }

    // ─── Orders ─────────────────────────────────────────────────────
    // Customers can create orders and read their own orders.
    // Cashiers can read orders only for their activeBranchId + activeStoreId.
    // Admins can read all orders.

    match /orders/{orderId} {
      // Read: owner sees own, cashier sees only branch/store matches, admin sees all
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) ||
        isAdmin() ||
        (isCashier() &&
         resource.data.branchId == getUserActiveBranchId() &&
         (getUserActiveStoreId() == null || resource.data.storeId == getUserActiveStoreId()))
      );
      // Create: validate branchId/storeId exist, status must be Pending
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.branchId != null &&
        request.resource.data.storeId != null &&
        request.resource.data.status == 'Pending' &&
        isValidOrderStatus(request.resource.data.status);
      // Update: cashier can update status within valid values, customer can cancel pending
      allow update: if isCashier() && isValidOrderStatus(request.resource.data.status) ||
        // Customer can cancel their own pending order
        (isOwner(resource.data.userId) &&
         resource.data.status == 'Pending' &&
         request.resource.data.status == 'Cancelled');
      allow delete: if isAdmin();
    }

    // ─── Payments ───────────────────────────────────────────────────
    // Customers can read their order's payment. Cashiers/Admins can read/write.

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        isCashier() ||
        get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isCashier();
      allow delete: if isAdmin();
    }

    // ─── Notifications ──────────────────────────────────────────────
    // Users can only read their own notifications.
    // Cashiers/admins can create customer notifications. Users can create only for themselves.

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      // Create: cashiers/admins can notify any user; users can only create their own.
      allow create: if isAuthenticated() &&
        (isCashier() || request.resource.data.userId == request.auth.uid) &&
        request.resource.data.userId is string &&
        request.resource.data.userId.size() > 0 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.isRead is bool;
      // Update: user can only update their own notifications (e.g., mark as read)
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ─── Announcements ──────────────────────────────────────────────
    // All authenticated users can read. Only admins can write.

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
